# === Discord ===
DISCORD_TOKEN=your-bot-token
CLIENT_ID=your-application-id
# Isi GUILD_ID untuk deploy slash command cepat ke 1 server (dev). Kosongkan untuk deploy global.
GUILD_ID=optional-guild-id-untuk-deploy-cepat

# === Supabase ===
SUPABASE_URL=https://xxxx.supabase.co
# WAJIB pakai Service Role Key (server-side only). JANGAN pernah ekspos ke client/browser.
SUPABASE_SERVICE_KEY=your-service-role-key
